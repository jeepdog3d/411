    <script>
        function toggleMobileMenu() {
            const menu = document.getElementById('mobile-menu')
            const icon = document.getElementById('mobile-menu-icon')
            menu.classList.toggle('hidden')
            if (icon.classList.contains('fa-bars')) {
                icon.classList.remove('fa-bars')
                icon.classList.add('fa-xmark')
            } else {
                icon.classList.remove('fa-xmark')
                icon.classList.add('fa-bars')
            }
        }
        
        function showImageModal(src) {
            const modal = document.getElementById('modal')
            const modalImg = document.getElementById('modal-image')
            modalImg.src = src
            modal.classList.remove('hidden')
            modal.classList.add('flex')
        }
        
        function hideModal() {
            const modal = document.getElementById('modal')
            modal.classList.add('hidden')
            modal.classList.remove('flex')
        }
        
        function submitForm() {
            const form = document.getElementById('contact-form')
            const originalText = form.querySelector('button').innerHTML
            form.querySelector('button').innerHTML = `<i class="fa-solid fa-spinner fa-spin mr-2"></i> SENDING...`
            setTimeout(() => {
                alert("✅ Thank you! Your inquiry has been received. (Demo — connect to your real CRM in production)")
                form.reset()
                form.querySelector('button').innerHTML = originalText
            }, 1400)
        }
        
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                if (this.getAttribute('href') === '#') return
                e.preventDefault()
                const target = document.querySelector(this.getAttribute('href'))
                if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' })
            })
        })
        
        console.log('%c✅ Updated property website template with Norman Rockwell-style Oconomowoc downtown hero loaded!', 'color:#166534; font-family:monospace')
    </script>

